# Build output and release artifacts
/dist/
*.deb
*.exe

# Native/object/shared artifacts
*.o
*.so
*.a
*.dll
*.dylib

# Exception: embedded assets (e.g. Mesa opengl32.dll baked in via go:embed).
# Anything under an assets/ directory is intentionally part of the source.
!**/assets/**

# Common extensionless executables
/a.out
/my_tool
/cve-parser

# Generic binary-like outputs
*.bin
*.out
